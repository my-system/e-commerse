// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Product {
  id          String   @id @default(cuid())
  title       String
  price       Float
  category    String
  description String?
  featured    Boolean  @default(false)
  inStock     Boolean  @default(true)
  rating      Float    @default(0)
  reviews     Int      @default(0)
  images      String   // JSON string of image URLs
  material    String?
  care        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  sizes       ProductSize[]
  colors      ProductColor[]
  specs       ProductSpec[]

  @@map("products")
}

model ProductSize {
  id        String @id @default(cuid())
  name      String
  value     String
  inStock   Boolean @default(true)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_sizes")
}

model ProductColor {
  id        String @id @default(cuid())
  name      String
  value     String // hex color
  inStock   Boolean @default(true)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_colors")
}

model ProductSpec {
  id        String @id @default(cuid())
  key       String
  value     String
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@map("product_specs")
}
