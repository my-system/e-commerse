# Production Environment Variables Template
# Copy this to .env.production and update with your actual values

# ==============================================
# DATABASE CONFIGURATION
# ==============================================
# Use Vercel Postgres or external PostgreSQL database
# Format: postgresql://username:password@host:port/database

PENDING_DATABASE_URL="postgresql://username:password@host:port/database_name"
MARKETPLACE_DATABASE_URL="postgresql://username:password@host:port/database_name"
BACKUP_DATABASE_URL="postgresql://username:password@host:port/database_name"
DATABASE_URL="postgresql://username:password@host:port/database_name"

# ==============================================
# AUTHENTICATION CONFIGURATION
# ==============================================
# Generate a secure random string (32+ characters)
# Use: openssl rand -base64 32

NEXTAUTH_SECRET="your-super-secret-random-string-at-least-32-characters-long"

# Your deployed application URL
NEXTAUTH_URL="https://your-domain.vercel.app"

# ==============================================
# ENVIRONMENT CONFIGURATION
# ==============================================
NODE_ENV="production"

# ==============================================
# OPTIONAL: EXTERNAL SERVICES
# ==============================================
# Uncomment and configure if using these services

# UploadThing for file uploads
# UPLOADTHING_SECRET="your-uploadthing-secret"
# UPLOADTHING_APP_ID="your-uploadthing-app-id"

# Resend for email services
# RESEND_API_KEY="your-resend-api-key"

# Stripe for payments
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Google OAuth (optional)
# GOOGLE_CLIENT_ID="your-google-client-id"
# GOOGLE_CLIENT_SECRET="your-google-client-secret"

# ==============================================
# VERCEL SPECIFIC
# ==============================================
# These will be automatically set by Vercel
# VERCEL_URL="https://your-domain.vercel.app"
# VERCEL_ENV="production"

# ==============================================
# DATABASE ALTERNATIVES
# ==============================================
# If using Vercel Postgres, get these from Vercel dashboard:
# DATABASE_URL="postgres://user:pass@host.vercel.db:5432/db?sslmode=require"
# DIRECT_URL="postgres://user:pass@host.vercel.db:5432/db?sslmode=require"

# If using Supabase:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# If using Railway:
# DATABASE_URL="postgresql://postgres:[PASSWORD]@[HOST].railway.app:5432/railway"

# ==============================================
# SECURITY NOTES
# ==============================================
# 1. Never commit this file to version control
# 2. Use strong, unique secrets
# 3. Rotate secrets regularly
# 4. Use SSL connections for databases
# 5. Limit database access to Vercel IPs

# ==============================================
# DEPLOYMENT CHECKLIST
# ==============================================
# [ ] Replace all placeholder values
# [ ] Test database connections
# [ ] Verify NEXTAUTH_SECRET is 32+ chars
# [ ] Set NEXTAUTH_URL to deployed domain
# [ ] Add variables to Vercel dashboard
# [ ] Test all functionality after deploy
